
@{
    ViewBag.Title = "Resistencia";
}

@model List<IDGS904ASP.Models.Resistencia>

<div class="container">

    <div class="row">

        <form action="/Resistencia/Resistencia" method="post">

            <div class="col-md-3">

                <h3>Primera Banda</h3>

                <select name="Color1">
                    <option>Negro</option>
                    <option>Cafe</option>
                    <option>Rojo</option>
                    <option>Naranja</option>
                    <option>Amarillo</option>
                    <option>Verde</option>
                    <option>Azul</option>
                    <option>Violeta</option>
                    <option>Gris</option>
                    <option>Blanco</option>
                </select>

            </div>


            <div class="col-md-3">

                <h3>Segunda Banda</h3>

                <select name="Color2">
                    <option>Negro</option>
                    <option>Cafe</option>
                    <option>Rojo</option>
                    <option>Naranja</option>
                    <option>Amarillo</option>
                    <option>Verde</option>
                    <option>Azul</option>
                    <option>Violeta</option>
                    <option>Gris</option>
                    <option>Blanco</option>
                </select>

            </div>


            <div class="col-md-3">

                <h3>Tercera Banda</h3>

                <select name="Color3">
                    <option>Negro</option>
                    <option>Cafe</option>
                    <option>Rojo</option>
                    <option>Naranja</option>
                    <option>Amarillo</option>
                    <option>Verde</option>
                    <option>Azul</option>
                    <option>Violeta</option>
                    <option>Gris</option>
                    <option>Blanco</option>
                </select>

            </div>


            <div class="col-md-3">

                <h3>Tolerancia</h3>

                <input type="radio" name="Tolerancia" value="Oro" /> Oro
                <input type="radio" name="Tolerancia" value="Plata" /> Plata

            </div>

            <br />
            <br />

            <input type="submit" value="Registrar" class="btn btn-primary" />

        </form>

    </div>

    <br />

    <div class="row">

        <table class="table table-bordered">

            <thead>
                <tr>
                    <th>Color1</th>
                    <th>Color2</th>
                    <th>Color3</th>
                    <th>Tolerancia</th>
                    <th>Valor</th>
                    <th>Valor mínimo</th>
                    <th>Valor máximo</th>
                </tr>
            </thead>

            <tbody>

                @foreach (var item in Model)
                {
                    <tr>

                        <td style="background-color:@item.ObtenerColorCss(item.Color1); color:white;">
                            @item.Color1
                        </td>

                        <td style="background-color:@item.ObtenerColorCss(item.Color2); color:white;">
                            @item.Color2
                        </td>

                        <td style="background-color:@item.ObtenerColorCss(item.Color3); color:white;">
                            @item.Color3
                        </td>

                        <td>@item.Tolerancia</td>

                        <td>@item.Valor</td>

                        <td>@item.Minimo</td>

                        <td>@item.Maximo</td>

                    </tr>
                }

            </tbody>

        </table>

    </div>

</div>

